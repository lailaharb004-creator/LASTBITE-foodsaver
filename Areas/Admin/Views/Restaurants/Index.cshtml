@using LastBiteNew.Models
@using LastBiteNew.ViewModels.Admin
@model List<RestaurantRowViewModel>
@{
    ViewData["Title"] = "Restaurants";
    Layout = "_AdminLayout";

    string StatusColor(RestaurantStatus s) => s switch
    {
        RestaurantStatus.Approved  => "#2D6A4F",
        RestaurantStatus.Pending   => "#F4A261",
        RestaurantStatus.Suspended => "#6c757d",
        RestaurantStatus.Rejected  => "#E63946",
        _                          => "#6c757d"
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">All Restaurants</h4>
    <small class="text-muted">@Model.Count restaurant@(Model.Count != 1 ? "s" : "")</small>
</div>

<!-- Filter Tabs -->
<div class="d-flex flex-wrap gap-2 mb-4">
    <a href="/Admin/Restaurants/Index"
       class="btn btn-sm @(ViewBag.CurrentStatus == null ? "btn-success" : "btn-outline-success")">
        All
    </a>
    <a href="/Admin/Restaurants/Index?status=Approved"
       class="btn btn-sm @(ViewBag.CurrentStatus == "Approved" ? "btn-success" : "btn-outline-success")">
        Approved
    </a>
    <a href="/Admin/Restaurants/Index?status=Pending"
       class="btn btn-sm @(ViewBag.CurrentStatus == "Pending" ? "btn-warning" : "btn-outline-warning")">
        Pending
    </a>
    <a href="/Admin/Restaurants/Index?status=Suspended"
       class="btn btn-sm @(ViewBag.CurrentStatus == "Suspended" ? "btn-danger" : "btn-outline-danger")">
        Suspended
    </a>
    <a href="/Admin/Restaurants/Index?status=Rejected"
       class="btn btn-sm @(ViewBag.CurrentStatus == "Rejected" ? "btn-secondary" : "btn-outline-secondary")">
        Rejected
    </a>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5 text-muted">
            <div style="font-size:3rem;">🏪</div>
            <p class="fw-semibold mt-3 mb-1">No restaurants found</p>
            <p class="small mb-0">No restaurants match the selected filter.</p>
        </div>
    </div>
}
else
{
    <!-- ── Desktop Table (md and up) ───────────────────────── -->
    <div class="card d-none d-md-block">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr style="background:#f0f4f0; border-bottom:2px solid #dee2e6;">
                        <th class="ps-4 py-3" style="color:#2D6A4F;font-size:0.78rem;text-transform:uppercase;letter-spacing:.05em;">Restaurant</th>
                        <th class="py-3"       style="color:#2D6A4F;font-size:0.78rem;text-transform:uppercase;letter-spacing:.05em;">Owner</th>
                        <th class="py-3"       style="color:#2D6A4F;font-size:0.78rem;text-transform:uppercase;letter-spacing:.05em;">Category</th>
                        <th class="py-3"       style="color:#2D6A4F;font-size:0.78rem;text-transform:uppercase;letter-spacing:.05em;">City</th>
                        <th class="py-3"       style="color:#2D6A4F;font-size:0.78rem;text-transform:uppercase;letter-spacing:.05em;">Rating</th>
                        <th class="py-3"       style="color:#2D6A4F;font-size:0.78rem;text-transform:uppercase;letter-spacing:.05em;">Status</th>
                        <th class="py-3 pe-4"  style="color:#2D6A4F;font-size:0.78rem;text-transform:uppercase;letter-spacing:.05em;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr style="border-left:3px solid @StatusColor(r.Status);">
                            <td class="ps-4 py-3">
                                <div class="fw-semibold">@r.Name</div>
                                <small class="text-muted">Since @r.CreatedAt.ToString("MMM yyyy")</small>
                            </td>
                            <td class="py-3">
                                <div class="fw-semibold">@r.OwnerName</div>
                                <small class="text-muted">@r.OwnerEmail</small>
                            </td>
                            <td class="py-3">
                                <span class="badge" style="background:#e8f5e9;color:#2D6A4F;font-size:0.75rem;">@r.Category</span>
                            </td>
                            <td class="py-3">@r.City</td>
                            <td class="py-3">
                                <span class="fw-semibold">⭐ @r.AverageRating.ToString("F1")</span>
                            </td>
                            <td class="py-3">
                                <span class="badge badge-@r.Status.ToString().ToLower() px-2 py-1">@r.Status</span>
                            </td>
                            <td class="py-3 pe-4">
                                @switch (r.Status)
                                {
                                    case RestaurantStatus.Pending:
                                        <form action="/Admin/Restaurants/Approve/@r.RestaurantId" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-success btn-sm">Approve</button>
                                        </form>
                                        <button type="button" class="btn btn-outline-danger btn-sm ms-1"
                                                onclick="showRejectModal(@r.RestaurantId, '@r.Name')">
                                            Reject
                                        </button>
                                        break;

                                    case RestaurantStatus.Approved:
                                        <form action="/Admin/Restaurants/Suspend/@r.RestaurantId" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="button" class="btn btn-warning btn-sm"
                                                    onclick="showSuspendConfirm('@r.Name', this.closest('form'))">
                                                Suspend
                                            </button>
                                        </form>
                                        <button type="button" class="btn btn-outline-danger btn-sm ms-1"
                                                onclick="showRejectModal(@r.RestaurantId, '@r.Name')">
                                            Reject
                                        </button>
                                        break;

                                    case RestaurantStatus.Suspended:
                                        <form action="/Admin/Restaurants/Unsuspend/@r.RestaurantId" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-success btn-sm">Restore</button>
                                        </form>
                                        <button type="button" class="btn btn-outline-danger btn-sm ms-1"
                                                onclick="showRejectModal(@r.RestaurantId, '@r.Name')">
                                            Reject
                                        </button>
                                        break;

                                    case RestaurantStatus.Rejected:
                                        <form action="/Admin/Restaurants/Approve/@r.RestaurantId" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-success btn-sm">Approve</button>
                                        </form>
                                        break;
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- ── Mobile Cards (below md) ─────────────────────────── -->
    <div class="d-md-none">
        @foreach (var r in Model)
        {
            <div class="card mb-3" style="border-left:4px solid @StatusColor(r.Status); box-shadow:0 2px 8px rgba(0,0,0,0.07);">
                <div class="card-body p-3">

                    <!-- Row 1: Name + Status -->
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <div class="fw-bold" style="font-size:1rem;">@r.Name</div>
                            <span class="badge mt-1" style="background:#e8f5e9;color:#2D6A4F;font-size:0.7rem;">@r.Category</span>
                        </div>
                        <span class="badge badge-@r.Status.ToString().ToLower() ms-2">@r.Status</span>
                    </div>

                    <!-- Row 2: Owner -->
                    <div class="mb-2">
                        <div class="fw-semibold" style="font-size:0.875rem;">@r.OwnerName</div>
                        <small class="text-muted">@r.OwnerEmail</small>
                    </div>

                    <!-- Row 3: City + Rating -->
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <div class="text-muted" style="font-size:0.72rem;text-transform:uppercase;letter-spacing:.04em;">City</div>
                            <div class="fw-semibold">@r.City</div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted" style="font-size:0.72rem;text-transform:uppercase;letter-spacing:.04em;">Rating</div>
                            <div class="fw-semibold">⭐ @r.AverageRating.ToString("F1")</div>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="pt-2" style="border-top:1px solid #f0f0f0;">
                        @switch (r.Status)
                        {
                            case RestaurantStatus.Pending:
                                <div class="d-flex gap-2">
                                    <form action="/Admin/Restaurants/Approve/@r.RestaurantId" method="post" class="flex-grow-1">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-success btn-sm w-100">Approve</button>
                                    </form>
                                    <button type="button" class="btn btn-outline-danger btn-sm flex-grow-1"
                                            onclick="showRejectModal(@r.RestaurantId, '@r.Name')">
                                        Reject
                                    </button>
                                </div>
                                break;

                            case RestaurantStatus.Approved:
                                <div class="d-flex gap-2">
                                    <form action="/Admin/Restaurants/Suspend/@r.RestaurantId" method="post" class="flex-grow-1">
                                        @Html.AntiForgeryToken()
                                        <button type="button" class="btn btn-warning btn-sm w-100"
                                                onclick="showSuspendConfirm('@r.Name', this.closest('form'))">
                                            Suspend
                                        </button>
                                    </form>
                                    <button type="button" class="btn btn-outline-danger btn-sm flex-grow-1"
                                            onclick="showRejectModal(@r.RestaurantId, '@r.Name')">
                                        Reject
                                    </button>
                                </div>
                                break;

                            case RestaurantStatus.Suspended:
                                <div class="d-flex gap-2">
                                    <form action="/Admin/Restaurants/Unsuspend/@r.RestaurantId" method="post" class="flex-grow-1">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-success btn-sm w-100">Restore</button>
                                    </form>
                                    <button type="button" class="btn btn-outline-danger btn-sm flex-grow-1"
                                            onclick="showRejectModal(@r.RestaurantId, '@r.Name')">
                                        Reject
                                    </button>
                                </div>
                                break;

                            case RestaurantStatus.Rejected:
                                <form action="/Admin/Restaurants/Approve/@r.RestaurantId" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-success btn-sm w-100">Approve</button>
                                </form>
                                break;
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- Reject Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title fw-bold">Reject Restaurant</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="rejectForm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <p class="mb-3">Rejecting: <strong id="restaurantNameText"></strong></p>
                    <label class="form-label fw-semibold">Reason for rejection</label>
                    <textarea name="reason" class="form-control" rows="3"
                              placeholder="Explain why this application is rejected..."
                              required></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger btn-sm">Confirm Reject</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function showRejectModal(id, name) {
            document.getElementById('restaurantNameText').textContent = name;
            document.getElementById('rejectForm').action = '/Admin/Restaurants/Reject/' + id;
            new bootstrap.Modal(document.getElementById('rejectModal')).show();
        }

        function showSuspendConfirm(name, form) {
            Swal.fire({
                title: 'Suspend Restaurant?',
                html: 'Are you sure you want to suspend <strong>' + name + '</strong>?<br><span style="font-size:0.875rem;color:#6b7280;">All active packages will be cancelled.</span>',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#f59e0b',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Yes, Suspend',
                cancelButtonText: 'Cancel'
            }).then(function (result) {
                if (result.isConfirmed) form.submit();
            });
        }
    </script>
}
