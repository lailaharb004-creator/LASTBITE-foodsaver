@using LastBiteNew.ViewModels.Admin
@model List<UserRowViewModel>
@{
    ViewData["Title"] = "All Users";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">All Users</h4>
    <span class="text-muted small">@Model.Count user@(Model.Count != 1 ? "s" : "")</span>
</div>

<!-- Filters -->
<form method="get" class="row g-2 mb-4">
    <div class="col-md-4">
        <input type="text" name="q" value="@ViewBag.Query" class="form-control" placeholder="Search name or email..." />
    </div>
    <div class="col-md-3">
        <select name="role" class="form-select" onchange="this.form.submit()">
            <option value="">All roles</option>
            <option value="Customer"        selected="@(ViewBag.CurrentRole == "Customer")">Customer</option>
            <option value="RestaurantOwner" selected="@(ViewBag.CurrentRole == "RestaurantOwner")">Restaurant Owner</option>
            <option value="Admin"           selected="@(ViewBag.CurrentRole == "Admin")">Admin</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-success w-100">Filter</button>
    </div>
</form>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">User</th>
                    <th>Role</th>
                    <th>Joined</th>
                    <th>Reservations</th>
                    <th>Reviews</th>
                    <th>Status</th>
                    <th class="pe-4">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="fw-semibold">@u.FullName</div>
                            <small class="text-muted">@u.Email</small>
                        </td>
                        <td><span class="badge bg-secondary">@u.Role</span></td>
                        <td><small>@u.CreatedAt.ToString("MMM d, yyyy")</small></td>
                        <td>@u.Reservations</td>
                        <td>@u.Reviews</td>
                        <td>
                            @if (u.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Banned</span>
                            }
                        </td>
                        <td class="pe-4">
                            @if (u.Role == "Admin")
                            {
                                <span class="text-muted small">—</span>
                            }
                            else if (u.IsActive)
                            {
                                <form asp-area="Admin" asp-controller="Users" asp-action="Ban" asp-route-id="@u.Id" method="post"
                                      onsubmit="return confirm('Ban @u.FullName? They will not be able to log in.');" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger">Ban</button>
                                </form>
                            }
                            else
                            {
                                <form asp-area="Admin" asp-controller="Users" asp-action="Unban" asp-route-id="@u.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-success">Unban</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
