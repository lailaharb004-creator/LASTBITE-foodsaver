@model List<ReservationRowViewModel>
@{
    ViewData["Title"] = "Reservations";
    Layout = "_RestaurantLayout";

    string StatusColor(ReservationStatus s) => s switch
    {
        ReservationStatus.Completed            => "#2D6A4F",
        ReservationStatus.Pending              => "#F4A261",
        ReservationStatus.NoShow               => "#6c757d",
        ReservationStatus.CancelledByCustomer  => "#E63946",
        ReservationStatus.CancelledByRestaurant=> "#E63946",
        _                                      => "#6c757d"
    };

    string StatusLabel(ReservationStatus s) => s switch
    {
        ReservationStatus.CancelledByCustomer   => "Cancelled",
        ReservationStatus.CancelledByRestaurant => "Cancelled by you",
        ReservationStatus.NoShow                => "No-Show",
        _                                       => s.ToString()
    };

    string TabHref(string? st)
    {
        var q = new List<string>();
        if (!string.IsNullOrEmpty(st)) q.Add("status=" + st);
        if (ViewBag.PackageId != null) q.Add("packageId=" + ViewBag.PackageId);
        var rng = ViewBag.CurrentRange as string;
        if (!string.IsNullOrEmpty(rng)) q.Add("range=" + rng);
        return "/Restaurant/Reservations/Index" + (q.Count > 0 ? "?" + string.Join("&", q) : "");
    }
}

<div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
    <div>
        <h4 class="fw-bold mb-0">Reservations</h4>
        @if (ViewBag.PackageName != null)
        {
            <div class="small text-muted mt-1">
                Package: <strong>@ViewBag.PackageName</strong>
                <a href="/Restaurant/Reservations/Index" class="ms-2 text-decoration-none">✕ clear</a>
            </div>
        }
        else
        {
            <small class="text-muted">@ViewBag.RestaurantName</small>
        }
    </div>
    <div class="d-flex align-items-center gap-2">
        <form method="get" class="d-flex align-items-center gap-2 mb-0">
            @if (ViewBag.CurrentStatus != null)
            {
                <input type="hidden" name="status" value="@ViewBag.CurrentStatus" />
            }
            @if (ViewBag.PackageId != null)
            {
                <input type="hidden" name="packageId" value="@ViewBag.PackageId" />
            }
            <select name="range" class="form-select form-select-sm" style="width:auto;" onchange="this.form.submit()">
                <option value="">All time</option>
                <option value="today" selected="@(ViewBag.CurrentRange as string == "today")">Today</option>
                <option value="week" selected="@(ViewBag.CurrentRange as string == "week")">Last 7 days</option>
            </select>
        </form>
        <a href="/Restaurant/Reservations/Export?status=@(ViewBag.CurrentStatus)&packageId=@(ViewBag.PackageId)&range=@(ViewBag.CurrentRange)"
           class="btn btn-sm btn-outline-success">⬇ Export CSV</a>
    </div>
</div>

<!-- Filter Tabs -->
<div class="d-flex flex-wrap gap-2 mb-4">
    <a href="@TabHref(null)"
       class="btn btn-sm @(ViewBag.CurrentStatus == null ? "btn-success" : "btn-outline-success")">
        All <span class="badge bg-white text-success ms-1">@Model.Count</span>
    </a>
    <a href="@TabHref("Pending")"
       class="btn btn-sm @(ViewBag.CurrentStatus == "Pending" ? "btn-warning" : "btn-outline-warning")">Pending</a>
    <a href="@TabHref("Completed")"
       class="btn btn-sm @(ViewBag.CurrentStatus == "Completed" ? "btn-success" : "btn-outline-success")">Completed</a>
    <a href="@TabHref("NoShow")"
       class="btn btn-sm @(ViewBag.CurrentStatus == "NoShow" ? "btn-secondary" : "btn-outline-secondary")">No-Show</a>
    <a href="@TabHref("CancelledByCustomer")"
       class="btn btn-sm @(ViewBag.CurrentStatus == "CancelledByCustomer" ? "btn-danger" : "btn-outline-danger")">Cancelled</a>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5 text-muted">
            <div style="font-size:3rem;">📋</div>
            <p class="fw-semibold mt-3 mb-1">No reservations found</p>
            <p class="small mb-0">
                @if (ViewBag.CurrentStatus != null)
                {
                    <span>No @(ViewBag.CurrentStatus.ToString().ToLower()) reservations yet.</span>
                }
                else
                {
                    <span>Reservations will appear here once customers book your packages.</span>
                }
            </p>
        </div>
    </div>
}
else
{
    <!-- ── Desktop Table (md and up) ───────────────────────── -->
    <div class="card d-none d-md-block">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr style="background:#f0f4f0; border-bottom:2px solid #dee2e6;">
                        <th class="ps-4 py-3" style="color:#2D6A4F;font-size:0.78rem;text-transform:uppercase;letter-spacing:.05em;">Code</th>
                        <th class="py-3"       style="color:#2D6A4F;font-size:0.78rem;text-transform:uppercase;letter-spacing:.05em;">Customer</th>
                        <th class="py-3"       style="color:#2D6A4F;font-size:0.78rem;text-transform:uppercase;letter-spacing:.05em;">Package</th>
                        <th class="py-3"       style="color:#2D6A4F;font-size:0.78rem;text-transform:uppercase;letter-spacing:.05em;">Qty</th>
                        <th class="py-3"       style="color:#2D6A4F;font-size:0.78rem;text-transform:uppercase;letter-spacing:.05em;">Total</th>
                        <th class="py-3"       style="color:#2D6A4F;font-size:0.78rem;text-transform:uppercase;letter-spacing:.05em;">Pickup</th>
                        <th class="py-3"       style="color:#2D6A4F;font-size:0.78rem;text-transform:uppercase;letter-spacing:.05em;">Status</th>
                        <th class="py-3 pe-4"  style="color:#2D6A4F;font-size:0.78rem;text-transform:uppercase;letter-spacing:.05em;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr style="border-left:3px solid @StatusColor(r.Status);">
                            <td class="ps-4 py-3">
                                <code class="fw-semibold" style="color:#2D6A4F;">@r.ReservationCode</code>
                                <div><small class="text-muted">@r.ReservedAt.ToString("MMM d, yyyy")</small></div>
                            </td>
                            <td class="py-3">
                                <div class="fw-semibold">@r.CustomerName</div>
                                <small class="text-muted">@r.CustomerEmail</small>
                            </td>
                            <td class="py-3">@r.PackageName</td>
                            <td class="py-3 fw-semibold">@r.Quantity</td>
                            <td class="py-3 fw-semibold text-success">JD @r.TotalPrice.ToString("N2")</td>
                            <td class="py-3">
                                <div class="fw-semibold" style="font-size:0.875rem;">@r.PickupStartTime.ToString("MMM d")</div>
                                <div>
                                    <small class="text-muted">@r.PickupStartTime.ToString("HH:mm") – @r.PickupEndTime.ToString("HH:mm")</small>
                                    @if (r.IsPickupActive)
                                    {
                                        <span class="badge bg-success ms-1" style="font-size:0.65rem;">Live</span>
                                    }
                                    else if (r.IsPickupPassed && r.Status == ReservationStatus.Pending)
                                    {
                                        <span class="badge bg-warning text-dark ms-1" style="font-size:0.65rem;">Overdue</span>
                                    }
                                </div>
                            </td>
                            <td class="py-3">
                                <span class="badge badge-@r.Status.ToString().ToLower() px-2 py-1">
                                    @StatusLabel(r.Status)
                                </span>
                            </td>
                            <td class="py-3 pe-4">
                                @if (r.Status == ReservationStatus.Pending)
                                {
                                    <form action="/Restaurant/Reservations/Complete/@r.ReservationId" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-success btn-sm">✓ Done</button>
                                    </form>
                                    <form action="/Restaurant/Reservations/NoShow/@r.ReservationId" method="post" class="d-inline ms-1">
                                        @Html.AntiForgeryToken()
                                        <button type="button" class="btn btn-outline-secondary btn-sm"
                                                onclick="confirmNoShow('@r.ReservationCode', this.closest('form'))">
                                            No-Show
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- ── Mobile Cards (below md) ─────────────────────────── -->
    <div class="d-md-none">
        @foreach (var r in Model)
        {
            <div class="card mb-3" style="border-left:4px solid @StatusColor(r.Status); box-shadow:0 2px 8px rgba(0,0,0,0.07);">
                <div class="card-body p-3">

                    <!-- Row 1: Code + Status -->
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <code class="fw-bold" style="color:#2D6A4F; font-size:0.95rem;">@r.ReservationCode</code>
                            <div><small class="text-muted">@r.ReservedAt.ToString("MMM d, yyyy")</small></div>
                        </div>
                        <span class="badge badge-@r.Status.ToString().ToLower() ms-2">@StatusLabel(r.Status)</span>
                    </div>

                    <!-- Row 2: Customer + Package -->
                    <div class="mb-2">
                        <div class="fw-semibold">@r.CustomerName</div>
                        <small class="text-muted">@r.CustomerEmail</small>
                        <div class="mt-1">
                            <span class="badge" style="background:#e8f5e9;color:#2D6A4F;font-size:0.72rem;">@r.PackageName</span>
                        </div>
                    </div>

                    <!-- Row 3: Qty + Total + Pickup -->
                    <div class="row g-2 mb-3">
                        <div class="col-4">
                            <div class="text-muted" style="font-size:0.72rem;text-transform:uppercase;letter-spacing:.04em;">Qty</div>
                            <div class="fw-bold">@r.Quantity</div>
                        </div>
                        <div class="col-4">
                            <div class="text-muted" style="font-size:0.72rem;text-transform:uppercase;letter-spacing:.04em;">Total</div>
                            <div class="fw-bold text-success" style="font-size:0.9rem;">JD @r.TotalPrice.ToString("N2")</div>
                        </div>
                        <div class="col-4">
                            <div class="text-muted" style="font-size:0.72rem;text-transform:uppercase;letter-spacing:.04em;">Pickup</div>
                            <div class="fw-semibold" style="font-size:0.8rem;">@r.PickupStartTime.ToString("MMM d")</div>
                            <small class="text-muted">@r.PickupStartTime.ToString("HH:mm")–@r.PickupEndTime.ToString("HH:mm")</small>
                            @if (r.IsPickupActive)
                            {
                                <span class="badge bg-success d-block mt-1" style="font-size:0.62rem;">Live</span>
                            }
                            else if (r.IsPickupPassed && r.Status == ReservationStatus.Pending)
                            {
                                <span class="badge bg-warning text-dark d-block mt-1" style="font-size:0.62rem;">Overdue</span>
                            }
                        </div>
                    </div>

                    <!-- Actions -->
                    @if (r.Status == ReservationStatus.Pending)
                    {
                        <div class="d-flex gap-2 pt-2" style="border-top:1px solid #f0f0f0;">
                            <form action="/Restaurant/Reservations/Complete/@r.ReservationId" method="post" class="flex-grow-1">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success btn-sm w-100">✓ Mark Done</button>
                            </form>
                            <form action="/Restaurant/Reservations/NoShow/@r.ReservationId" method="post" class="flex-grow-1">
                                @Html.AntiForgeryToken()
                                <button type="button" class="btn btn-outline-secondary btn-sm w-100"
                                        onclick="confirmNoShow('@r.ReservationCode', this.closest('form'))">
                                    No-Show
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmNoShow(code, form) {
            Swal.fire({
                title: 'Mark as No-Show?',
                html: 'Reservation <strong>' + code + '</strong> will be marked as no-show.<br><span style="font-size:0.875rem;color:#6b7280;">The quantity will be returned to the package.</span>',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#6c757d',
                cancelButtonColor: '#2D6A4F',
                confirmButtonText: 'Yes, No-Show',
                cancelButtonText: 'Keep'
            }).then(function (result) {
                if (result.isConfirmed) form.submit();
            });
        }
    </script>
}
