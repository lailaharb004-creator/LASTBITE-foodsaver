@model List<PackageRowViewModel>
@{
    ViewData["Title"] = "My Packages";
    Layout = "_RestaurantLayout";
}

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">My Packages</h4>
    <a href="/Restaurant/Packages/Create" class="btn btn-success btn-sm px-3">
        + Add Package
    </a>
</div>

<!-- Filter Tabs -->
<div class="d-flex flex-wrap gap-2 mb-4">
    <a href="/Restaurant/Packages/Index"
       class="btn btn-sm @(ViewBag.CurrentStatus == null ? "btn-success" : "btn-outline-success")">
        All
    </a>
    <a href="/Restaurant/Packages/Index?status=Active"
       class="btn btn-sm @(ViewBag.CurrentStatus == "Active" ? "btn-success" : "btn-outline-success")">
        Active
    </a>
    <a href="/Restaurant/Packages/Index?status=SoldOut"
       class="btn btn-sm @(ViewBag.CurrentStatus == "SoldOut" ? "btn-secondary" : "btn-outline-secondary")">
        Sold Out
    </a>
    <a href="/Restaurant/Packages/Index?status=Expired"
       class="btn btn-sm @(ViewBag.CurrentStatus == "Expired" ? "btn-warning" : "btn-outline-warning")">
        Expired
    </a>
    <a href="/Restaurant/Packages/Index?status=Cancelled"
       class="btn btn-sm @(ViewBag.CurrentStatus == "Cancelled" ? "btn-danger" : "btn-outline-danger")">
        Cancelled
    </a>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5 text-muted">
            <div style="font-size:3rem;">📦</div>
            <p class="fw-semibold mt-3 mb-1">No packages yet</p>
            <p class="small mb-3">Create your first package to start receiving reservations.</p>
            <a href="/Restaurant/Packages/Create" class="btn btn-success btn-sm px-4">
                + Add Package
            </a>
        </div>
    </div>
}
else
{
    <!-- ── Desktop Table (md and up) ───────────────────────── -->
    <div class="card d-none d-md-block">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr style="background:#f0f4f0; border-bottom: 2px solid #dee2e6;">
                        <th class="ps-4 py-3" style="color:#2D6A4F; font-size:0.78rem; text-transform:uppercase; letter-spacing:.05em;">Package</th>
                        <th class="py-3" style="color:#2D6A4F; font-size:0.78rem; text-transform:uppercase; letter-spacing:.05em;">Pricing</th>
                        <th class="py-3" style="color:#2D6A4F; font-size:0.78rem; text-transform:uppercase; letter-spacing:.05em;">Availability</th>
                        <th class="py-3" style="color:#2D6A4F; font-size:0.78rem; text-transform:uppercase; letter-spacing:.05em;">Pickup</th>
                        <th class="py-3" style="color:#2D6A4F; font-size:0.78rem; text-transform:uppercase; letter-spacing:.05em;">Status</th>
                        <th class="py-3 pe-4" style="color:#2D6A4F; font-size:0.78rem; text-transform:uppercase; letter-spacing:.05em;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr style="border-left: 3px solid @(p.Status == PackageStatus.Active ? "#2D6A4F" : p.Status == PackageStatus.SoldOut ? "#6c757d" : p.Status == PackageStatus.Expired ? "#f4a261" : "#dc3545");">
                            <td class="ps-4 py-3">
                                <div class="fw-semibold">@p.Name</div>
                                <span class="badge mt-1" style="background:#e8f5e9; color:#2D6A4F; font-weight:500; font-size:0.72rem;">@p.FoodType</span>
                            </td>
                            <td class="py-3">
                                <div class="fw-bold text-success fs-6">JD @p.DiscountedPrice.ToString("N2")</div>
                                <div class="d-flex align-items-center gap-1 mt-1">
                                    <small class="text-muted text-decoration-line-through">JD @p.OriginalPrice.ToString("N2")</small>
                                    <span class="savings-badge">-@p.SavingsPercent%</span>
                                </div>
                            </td>
                            <td class="py-3">
                                <div class="d-flex align-items-center gap-2">
                                    <div style="width:80px; height:6px; background:#e9ecef; border-radius:3px; overflow:hidden;">
                                        <div style="height:100%; width:@(p.TotalQuantity > 0 ? (p.RemainingQuantity * 100 / p.TotalQuantity) : 0)%; background:@(p.RemainingQuantity > 0 ? "#2D6A4F" : "#6c757d"); border-radius:3px;"></div>
                                    </div>
                                    <small class="text-muted">@p.RemainingQuantity / @p.TotalQuantity</small>
                                </div>
                                <small class="text-muted">@p.TotalReservations reservation@(p.TotalReservations != 1 ? "s" : "")</small>
                            </td>
                            <td class="py-3">
                                <div class="fw-semibold" style="font-size:0.875rem;">@p.PickupStartTime.ToString("MMM d")</div>
                                <small class="text-muted">@p.PickupStartTime.ToString("HH:mm") – @p.PickupEndTime.ToString("HH:mm")</small>
                            </td>
                            <td class="py-3">
                                <span class="badge badge-@p.Status.ToString().ToLower() px-2 py-1">
                                    @p.Status
                                </span>
                            </td>
                            <td class="py-3 pe-4">
                                <a href="/Restaurant/Reservations/Index?packageId=@p.PackageId"
                                   class="btn btn-outline-secondary btn-sm">Reservations</a>
                                @if (p.Status is not PackageStatus.Cancelled and not PackageStatus.Expired)
                                {
                                    <a href="/Restaurant/Packages/Edit/@p.PackageId"
                                       class="btn btn-outline-secondary btn-sm ms-1">Edit</a>
                                    <form action="/Restaurant/Packages/Cancel/@p.PackageId"
                                          method="post" class="d-inline ms-1">
                                        @Html.AntiForgeryToken()
                                        <button type="button" class="btn btn-outline-danger btn-sm"
                                                onclick="confirmCancel('@p.Name', this.closest('form'))">
                                            Cancel
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- ── Mobile Cards (below md) ─────────────────────────── -->
    <div class="d-md-none">
        @foreach (var p in Model)
        {
            <div class="card mb-3" style="border-left: 4px solid @(p.Status == PackageStatus.Active ? "#2D6A4F" : p.Status == PackageStatus.SoldOut ? "#6c757d" : p.Status == PackageStatus.Expired ? "#f4a261" : "#dc3545"); box-shadow: 0 2px 8px rgba(0,0,0,0.07);">
                <div class="card-body p-3">

                    <!-- Row 1: Name + Status -->
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <div class="fw-bold" style="font-size:1rem;">@p.Name</div>
                            <span class="badge mt-1" style="background:#e8f5e9; color:#2D6A4F; font-size:0.7rem;">@p.FoodType</span>
                        </div>
                        <span class="badge badge-@p.Status.ToString().ToLower() ms-2">@p.Status</span>
                    </div>

                    <!-- Row 2: Price -->
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="fw-bold text-success" style="font-size:1.15rem;">JD @p.DiscountedPrice.ToString("N2")</span>
                        <small class="text-muted text-decoration-line-through">JD @p.OriginalPrice.ToString("N2")</small>
                        <span class="savings-badge">-@p.SavingsPercent%</span>
                    </div>

                    <!-- Row 3: Availability bar + Pickup -->
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <div class="text-muted" style="font-size:0.72rem; text-transform:uppercase; letter-spacing:.04em; margin-bottom:4px;">Availability</div>
                            <div style="height:6px; background:#e9ecef; border-radius:3px; overflow:hidden;">
                                <div style="height:100%; width:@(p.TotalQuantity > 0 ? (p.RemainingQuantity * 100 / p.TotalQuantity) : 0)%; background:@(p.RemainingQuantity > 0 ? "#2D6A4F" : "#6c757d"); border-radius:3px;"></div>
                            </div>
                            <small class="text-muted mt-1 d-block">@p.RemainingQuantity of @p.TotalQuantity left</small>
                        </div>
                        <div class="col-6">
                            <div class="text-muted" style="font-size:0.72rem; text-transform:uppercase; letter-spacing:.04em; margin-bottom:4px;">Pickup</div>
                            <div class="fw-semibold" style="font-size:0.85rem;">@p.PickupStartTime.ToString("MMM d")</div>
                            <small class="text-muted">@p.PickupStartTime.ToString("HH:mm") – @p.PickupEndTime.ToString("HH:mm")</small>
                        </div>
                    </div>

                    <!-- Row 4: Reservations count + Actions -->
                    <div class="d-flex justify-content-between align-items-center pt-2" style="border-top:1px solid #f0f0f0;">
                        <small class="text-muted">
                            @p.TotalReservations reservation@(p.TotalReservations != 1 ? "s" : "")
                        </small>
                        <div class="d-flex gap-2 flex-wrap">
                            <a href="/Restaurant/Reservations/Index?packageId=@p.PackageId"
                               class="btn btn-outline-secondary btn-sm">Reservations</a>
                            @if (p.Status is not PackageStatus.Cancelled and not PackageStatus.Expired)
                            {
                                <a href="/Restaurant/Packages/Edit/@p.PackageId"
                                   class="btn btn-outline-secondary btn-sm">Edit</a>
                                <form action="/Restaurant/Packages/Cancel/@p.PackageId"
                                      method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="button" class="btn btn-outline-danger btn-sm"
                                            onclick="confirmCancel('@p.Name', this.closest('form'))">
                                        Cancel
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmCancel(name, form) {
            Swal.fire({
                title: 'Cancel Package?',
                html: 'Are you sure you want to cancel <strong>' + name + '</strong>?<br><span style="font-size:0.875rem;color:#6b7280;">All pending reservations will be cancelled and those customers notified.</span>',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Yes, Cancel It',
                cancelButtonText: 'Keep It'
            }).then(function (result) {
                if (result.isConfirmed) form.submit();
            });
        }
    </script>
}
