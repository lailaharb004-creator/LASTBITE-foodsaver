@using LastBiteNew.Models
@model List<Notification>
@{
    ViewData["Title"] = "Notifications";

    string Icon(NotificationType t) => t switch
    {
        NotificationType.Reservation => "📋",
        NotificationType.RestaurantApproval => "🏪",
        NotificationType.PackageCancellation => "⚠️",
        NotificationType.ReviewReminder => "⭐",
        _ => "🔔"
    };
}

<div class="container py-4" style="max-width:760px;">
    <h4 class="fw-bold mb-4">Notifications</h4>

    @if (!Model.Any())
    {
        <div class="card">
            <div class="card-body text-center py-5 text-muted">
                <div style="font-size:3rem;">🔔</div>
                <h5 class="mt-3 mb-1">No notifications yet</h5>
                <p class="small mb-0">We'll let you know when something happens.</p>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm" style="border-radius:14px; overflow:hidden;">
            @foreach (var n in Model)
            {
                <div class="d-flex gap-3 p-3" style="border-bottom:1px solid #f0f0f0;">
                    <div style="font-size:1.5rem; line-height:1;">@Icon(n.Type)</div>
                    <div class="flex-grow-1">
                        <div class="fw-semibold">@n.Title</div>
                        <div class="text-muted small">@n.Message</div>
                        <div class="text-muted" style="font-size:0.72rem;">@n.CreatedAt.ToLocalTime().ToString("MMM d, yyyy · HH:mm")</div>
                    </div>
                </div>
            }
        </div>
    }
</div>
