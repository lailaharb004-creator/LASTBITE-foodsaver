@using LastBiteNew.ViewModels.Customer
@model RestaurantProfileViewModel
@{
    ViewData["Title"] = Model.Name;

    string Stars(decimal rating)
    {
        int full = (int)Math.Round(rating, MidpointRounding.AwayFromZero);
        return string.Concat(Enumerable.Repeat("★", full)) + string.Concat(Enumerable.Repeat("☆", 5 - full));
    }
}

<!-- Cover -->
<div style="height:220px; position:relative;
            @(string.IsNullOrEmpty(Model.CoverImagePath)
                ? "background:linear-gradient(135deg,#1B4332,#52B788);"
                : $"background:url('{Model.CoverImagePath}') center/cover;")">
</div>

<div class="container" style="margin-top:-60px; position:relative; z-index:2;">
    <div class="card border-0 shadow-sm" style="border-radius:18px;">
        <div class="card-body p-4">
            <div class="d-flex flex-wrap align-items-center gap-3">
                <!-- Logo -->
                <div style="width:84px; height:84px; border-radius:16px; overflow:hidden; flex-shrink:0;
                            background:#f0f4f0; display:flex; align-items:center; justify-content:center;">
                    @if (!string.IsNullOrEmpty(Model.LogoPath))
                    {
                        <img src="@Model.LogoPath" alt="@Model.Name" style="width:100%; height:100%; object-fit:cover;" />
                    }
                    else
                    {
                        <span style="font-size:2.4rem;">🏪</span>
                    }
                </div>
                <div class="flex-grow-1">
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <h3 class="fw-bold mb-0">@Model.Name</h3>
                        <span class="badge" style="background:#e8f5e9;color:#2D6A4F;">@Model.Category</span>
                    </div>
                    <div class="text-muted mt-1" style="font-size:0.9rem;">📍 @Model.Address, @Model.City</div>
                    <div class="mt-1">
                        @if (Model.TotalReviews > 0)
                        {
                            <span style="color:#F4A261; letter-spacing:2px;">@Stars(Model.AverageRating)</span>
                            <span class="fw-semibold ms-1">@Model.AverageRating.ToString("F1")</span>
                            <span class="text-muted small">(@Model.TotalReviews review@(Model.TotalReviews != 1 ? "s" : ""))</span>
                        }
                        else
                        {
                            <span class="text-muted small">No reviews yet</span>
                        }
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <p class="text-muted mt-3 mb-0">@Model.Description</p>
            }
            <div class="d-flex flex-wrap gap-4 mt-3 small text-muted">
                @if (!string.IsNullOrWhiteSpace(Model.PhoneNumber))
                {
                    <div>📞 @Model.PhoneNumber</div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.OperatingHours))
                {
                    <div>🕒 @Model.OperatingHours</div>
                }
            </div>
        </div>
    </div>

    <!-- Active packages -->
    <div class="py-4">
        <h5 class="fw-bold mb-3">Available Packages</h5>
        @if (!Model.ActivePackages.Any())
        {
            <div class="text-muted small">No active packages right now — check back later.</div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var p in Model.ActivePackages)
                {
                    <div class="col-12 col-sm-6 col-lg-4">
                        <div class="card h-100" style="border-radius:14px; overflow:hidden; box-shadow:0 2px 12px rgba(0,0,0,0.08);">
                            @if (!string.IsNullOrEmpty(p.ImagePath))
                            {
                                <div style="height:130px; background:url('@p.ImagePath') center/cover;"></div>
                            }
                            else
                            {
                                <div style="height:130px; background:@PackageVisual.Gradient(p.FoodType); display:flex; align-items:center; justify-content:center;">
                                    <span style="font-size:3rem;">@PackageVisual.Icon(p.FoodType)</span>
                                </div>
                            }
                            <div class="card-body d-flex flex-column p-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div class="fw-bold" style="color:#1B4332;">@p.PackageName</div>
                                    <span class="savings-badge ms-2 flex-shrink-0">-@p.SavingsPercent%</span>
                                </div>
                                <div class="d-flex align-items-baseline gap-2 my-2">
                                    <span class="fw-bold text-success" style="font-size:1.2rem;">JD @p.DiscountedPrice.ToString("N2")</span>
                                    <small class="text-muted text-decoration-line-through">JD @p.OriginalPrice.ToString("N2")</small>
                                </div>
                                <div class="mb-2" style="font-size:0.82rem; color:#555;">
                                    ⏰ @p.PickupStartTime.ToString("MMM d, HH:mm") – @p.PickupEndTime.ToString("HH:mm")
                                </div>
                                <a href="/Packages/Details/@p.PackageId"
                                   class="btn @(p.AlreadyReserved ? "btn-outline-success" : "btn-success") btn-sm mt-auto">
                                    @(p.AlreadyReserved ? "✓ Already Reserved" : "View & Reserve")
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Reviews -->
    <div class="pb-5">
        <h5 class="fw-bold mb-3">Customer Reviews</h5>
        @if (!Model.Reviews.Any())
        {
            <div class="text-muted small">No reviews yet. Be the first to rescue a meal and leave one!</div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var rev in Model.Reviews)
                {
                    <div class="col-12 col-lg-6">
                        <div class="card border-0" style="border-radius:12px; background:#f8faf9;">
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="fw-semibold">@rev.CustomerName</span>
                                    <small class="text-muted">@rev.CreatedAt.ToString("MMM d, yyyy")</small>
                                </div>
                                <div style="color:#F4A261; letter-spacing:2px;">@Stars(rev.Rating)</div>
                                @if (!string.IsNullOrWhiteSpace(rev.Comment))
                                {
                                    <p class="mb-0 mt-2 small text-muted">@rev.Comment</p>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
