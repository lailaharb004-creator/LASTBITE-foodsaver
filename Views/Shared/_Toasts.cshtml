@{
    var success = TempData["Success"] as string;
    var error = TempData["Error"] as string;
}
@if (success != null || error != null)
{
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index:1090;">
        @if (success != null)
        {
            <div class="toast align-items-center text-white bg-success border-0 app-toast" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body">@success</div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        }
        @if (error != null)
        {
            <div class="toast align-items-center text-white bg-danger border-0 app-toast" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body">@error</div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        }
    </div>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.app-toast').forEach(function (el) {
                new bootstrap.Toast(el, { delay: 4000 }).show();
            });
        });
    </script>
}
